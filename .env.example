# =============================================================================
# Marketing Dashboard — environment variables
#
# Locked-in choices (Ahmed picked):
#   META:        Meta Marketing API (Graph API) — direct fetch calls.
#                Token scopes required: ads_read, leads_retrieval,
#                pages_read_engagement, pages_show_list, business_management.
#                Generate a long-lived user token or System User token at
#                https://developers.facebook.com/apps -> your app -> Marketing API.
#
#   SALESFORCE:  OAuth 2.0 Web-Server flow via jsforce.
#                Setup -> App Manager -> New Connected App.
#                Callback URL: ${APP_URL}/api/auth/salesforce/callback.
#                Scopes: api, refresh_token, offline_access.
#                Click "Connect Salesforce" on /dashboard/settings/integrations
#                to start the flow; tokens land in salesforce_connections.
#
# This file is the template. Put your real values in .env.local — it's
# git-ignored. Don't commit secrets to .env.example.
# =============================================================================


# ---- Supabase ---------------------------------------------------------------
# Get from https://app.supabase.com/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- App --------------------------------------------------------------------
APP_URL=http://localhost:3000
# Random 32+ char string used to sign sync-cron callbacks
SYNC_SECRET=replace-me-with-a-long-random-string


# ---- META MARKETING API (option 1a) ----------------------------------------
# https://developers.facebook.com/apps  → your app → Settings → Basic
META_APP_ID=
META_APP_SECRET=
# Long-lived user token OR System User token with ads_read + leads_retrieval
META_ACCESS_TOKEN=
# Comma-separated list of ad account ids you want to sync, e.g.  act_123,act_456
META_AD_ACCOUNT_IDS=
META_API_VERSION=v21.0


# ---- SALESFORCE (option 2a — OAuth Web Server flow) ------------------------
# Connected App → "Enable OAuth Settings"
SF_CLIENT_ID=
SF_CLIENT_SECRET=
# login.salesforce.com for prod, test.salesforce.com for sandbox
SF_LOGIN_URL=https://login.salesforce.com
SF_CALLBACK_URL=http://localhost:3000/api/auth/salesforce/callback

# Custom field names in your Salesforce org — edit if yours differ.
SF_LEAD_CAMPAIGN_FIELD=Campaign_Name__c
SF_BOOKING_OBJECT=Booking__c
SF_BOOKING_AMOUNT_FIELD=Booking_Price__c
SF_BOOKING_LEAD_LOOKUP_FIELD=Lead__c

# Commission fields on the Booking object (used by the Performance dashboard).
# Gross Commission = total commission earned on the deal.
# Net Commission   = Allegiance's share of the commission.
SF_BOOKING_GROSS_COMMISSION_FIELD=Total_Commission_Amount__c
SF_BOOKING_NET_COMMISSION_FIELD=Total_Allegiance_Commission__c
